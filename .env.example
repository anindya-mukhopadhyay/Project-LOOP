# Application
NEXT_PUBLIC_APP_NAME="Project LOOP"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_loop?schema=public"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-strong-32-character-minimum-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Optional development escape hatch for CI/bootstrap before secrets are provisioned.
SKIP_ENV_VALIDATION="0"
